# --- Railway ---
RAILWAY_PROJECT_ID=add85240-91e8-47ef-b390-c1fc2d14e166

# --- Microsoft Graph (app-only / client credentials) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Google APIs ---
GOOGLE_VISION_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_STT_API_KEY=

# --- OpenRouter (LLM gateway) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- Database ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Railway Object Storage (S3-compatible) ---
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_ENDPOINT=

# --- App ---
APP_ENV=development
SECRET_KEY=
FRONTEND_URL=http://localhost:3000

# --- Frontend (Next.js public env vars) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Feature Flags ---
# Set USE_MOCKS=true during development when external API keys are not yet available.
# MockGraphClient, MockVisionClient, MockLLMClient will be used instead.
USE_MOCKS=false

# --- Meeting Defaults ---
MEETING_DURATION_MINUTES=60
